# ============================================================================
# PR-Agent Configuration
# Copy this file to .env.local and fill in your actual values
# ============================================================================

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PR-Agent

# ============================================================================
# REQUIRED: Supabase Configuration
# Get these from your Supabase project settings
# https://supabase.com/dashboard
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx

# ============================================================================
# REQUIRED: OpenAI Configuration
# Get your API key from https://platform.openai.com/account/api-keys
# ============================================================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4

# ============================================================================
# OPTIONAL: GitHub Configuration
# For webhook support and GitHub API access
# ============================================================================
GITHUB_API_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=your-webhook-secret-min-20-chars
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----

# ============================================================================
# REQUIRED: Security Keys
# IMPORTANT: Generate new keys for production!
# 
# Generate ENCRYPTION_KEY:
#   openssl rand -hex 32
#
# Generate API_SIGNATURE_SECRET:
#   openssl rand -hex 16
# ============================================================================
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
API_SIGNATURE_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_WEBHOOKS=true
ENABLE_RATE_LIMITING=true
ENABLE_ANALYTICS=false

# ============================================================================
# Development & Debug
# ============================================================================
DEBUG=false
# For testing without authentication - remove in production!
# NEXT_PUBLIC_MOCK_USER_ID=user_12345

# ============================================================================
# API Timeouts (in milliseconds)
# ============================================================================
GITHUB_API_TIMEOUT_MS=10000
OPENAI_API_TIMEOUT_MS=30000
WEBHOOK_TIMEOUT_MS=30000

# ============================================================================
# OPTIONAL: Integrations
# ============================================================================
# Sentry error tracking
# SENTRY_DSN=https://xxxxxxx@xxxxxxx.ingest.sentry.io/123456

# Analytics
# ANALYTICS_ID=UA-XXXXXXXXX-X
