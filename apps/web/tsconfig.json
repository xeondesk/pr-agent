{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "preserve",
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@pr-agent/types": ["../../packages/types/src/index.ts"],
      "@pr-agent/core": ["../../packages/core/src/index.ts"],
      "@pr-agent/tools": ["../../packages/tools/src/index.ts"],
      "@pr-agent/agents": ["../../packages/agents/src/index.ts"],
      "@pr-agent/capability-types": ["../../packages/capability-types/src/index.ts"],
      "@pr-agent/capability-sdk": ["../../packages/capability-sdk/src/index.ts"],
      "@pr-agent/capability-registry": ["../../packages/capability-registry/src/index.ts"],
      "@pr-agent/capability-runtime": ["../../packages/capability-runtime/src/index.ts"],
      "@pr-agent/capability-cli": ["../../packages/capability-cli/src/index.ts"],
      "@pr-agent/git-providers": ["../../packages/git-providers/src/index.ts"],
      "@pr-agent/secret-providers": ["../../packages/secret-providers/src/index.ts"],
      "@pr-agent/identity-providers": ["../../packages/identity-providers/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
